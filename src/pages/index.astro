---
import "../styles/global.css";
import {
  Baby,
  CalendarDays,
  Car,
  Clock3,
  Download,
  Hotel,
  Luggage,
  MapPin,
  Plane,
  Save,
  Search,
  Sparkles,
  Star,
  Trash2,
  Utensils
} from "@lucide/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A family travel planner for finding toddler-friendly lodging, flights, restaurants, and activities."
    />
    <title>Family Travel Studio</title>
  </head>
  <body>
    <main class="app-shell">
      <header class="topbar" aria-label="Primary">
        <a class="brand" href="/" aria-label="Family Travel Studio home">
          <span class="brand-mark"><Luggage size={19} stroke-width={2.4} /></span>
          <span>Family Travel Studio</span>
        </a>
        <div class="topbar-actions">
          <nav class="nav-pills" aria-label="Planner views">
            <a href="#planner">Plan</a>
            <a href="#results">Options</a>
            <a href="#itinerary">Itinerary</a>
            <a href="#saved">Saved</a>
          </nav>
          <button class="signin-button" id="auth-button" type="button">Sign in</button>
        </div>
      </header>

      <section class="workspace" id="planner">
        <aside class="planner-panel" aria-label="Trip inputs">
          <div class="panel-heading">
            <p class="eyebrow"><Sparkles size={15} /> AI-ready planner</p>
            <h1>Build a family trip that respects nap time.</h1>
            <p class="quota-status" id="quota-status">Public demo includes 3 AI searches. Sign in as owner for unlimited.</p>
          </div>

          <form class="trip-form" id="trip-form">
            <label>
              <span><MapPin size={16} /> Destination</span>
              <input
                id="destination"
                name="destination"
                autocomplete="address-level2"
                placeholder="San Diego, CA"
                value="San Diego, CA"
                required
              />
            </label>

            <div class="field-grid">
              <label>
                <span><CalendarDays size={16} /> Depart</span>
                <input id="start-date" name="startDate" type="date" required />
              </label>
              <label>
                <span><CalendarDays size={16} /> Return</span>
                <input id="end-date" name="endDate" type="date" required />
              </label>
            </div>

            <div class="field-grid">
              <label>
                <span><Plane size={16} /> Home airport</span>
                <input id="origin" name="origin" maxlength="3" placeholder="AUS" value="AUS" />
              </label>
              <label>
                <span><Baby size={16} /> Kids</span>
                <select id="kids" name="kids">
                  <option value="1 and 2 year old">1 and 2 year old</option>
                  <option value="two toddlers">Two toddlers</option>
                  <option value="infant and toddler">Infant and toddler</option>
                </select>
              </label>
            </div>

            <fieldset>
              <legend>Trip style</legend>
              <div class="segmented">
                <input type="radio" id="pace-easy" name="pace" value="easy" checked />
                <label for="pace-easy">Easy</label>
                <input type="radio" id="pace-balanced" name="pace" value="balanced" />
                <label for="pace-balanced">Balanced</label>
                <input type="radio" id="pace-full" name="pace" value="full" />
                <label for="pace-full">Full</label>
              </div>
            </fieldset>

            <fieldset>
              <legend>Price ranges</legend>
              <div class="budget-grid">
                <label>
                  <span>Lodging / night</span>
                  <select name="lodgingBudget">
                    <option value="240">Up to $240</option>
                    <option value="360" selected>Up to $360</option>
                    <option value="520">Up to $520</option>
                    <option value="750">Up to $750</option>
                  </select>
                </label>
                <label>
                  <span>Flight / person</span>
                  <select name="flightBudget">
                    <option value="220">Up to $220</option>
                    <option value="360" selected>Up to $360</option>
                    <option value="520">Up to $520</option>
                    <option value="750">Up to $750</option>
                  </select>
                </label>
                <label>
                  <span>Meal for 4</span>
                  <select name="foodBudget">
                    <option value="45">Up to $45</option>
                    <option value="80" selected>Up to $80</option>
                    <option value="130">Up to $130</option>
                  </select>
                </label>
                <label>
                  <span>Activities / day</span>
                  <select name="activityBudget">
                    <option value="40">Up to $40</option>
                    <option value="100" selected>Up to $100</option>
                    <option value="200">Up to $200</option>
                  </select>
                </label>
              </div>
            </fieldset>

            <fieldset>
              <legend>Priorities</legend>
              <div class="checkbox-list">
                <label><input type="checkbox" name="priority" value="pool" checked /> Pool or splash pad</label>
                <label><input type="checkbox" name="priority" value="walkable" checked /> Walkable base</label>
                <label><input type="checkbox" name="priority" value="kitchen" /> Kitchenette</label>
                <label><input type="checkbox" name="priority" value="short-flights" checked /> Short flights</label>
              </div>
            </fieldset>

            <label>
              <span><Star size={16} /> Notes</span>
              <textarea
                id="notes"
                name="notes"
                rows="3"
                placeholder="Early dinners, stroller-friendly, avoid long drives..."
              ></textarea>
            </label>

            <button class="primary-action" type="submit">
              <Search size={18} />
              <span>Generate options</span>
            </button>
          </form>
        </aside>

        <section class="hero-board" aria-label="Planner preview">
          <div class="hero-image" role="img" aria-label="Family travel gear overlooking a sunny destination"></div>
          <div class="hero-copy">
            <p>Family of 4</p>
            <h2>Toddler-aware flights, lodging, food, and activities in one board.</h2>
          </div>
          <div class="quick-stats" aria-label="Planning focus">
            <span><Clock3 size={16} /> Nap windows</span>
            <span><Car size={16} /> Low-drive days</span>
            <span><Utensils size={16} /> Early meals</span>
          </div>
        </section>
      </section>

      <section class="results-layout" id="results" aria-live="polite">
        <div class="section-title">
          <p class="eyebrow"><Sparkles size={15} /> Trip options</p>
          <h2 id="plan-title">Start with a destination and dates.</h2>
        </div>

        <div class="result-actions">
          <button class="icon-button accent-action" id="build-trip" type="button" disabled title="Build itinerary">
            <Sparkles size={18} />
            <span>Build this trip</span>
          </button>
          <button class="icon-button" id="save-plan" type="button" disabled title="Save plan">
            <Save size={18} />
            <span>Save</span>
          </button>
          <button class="icon-button" id="download-plan" type="button" disabled title="Download plan">
            <Download size={18} />
            <span>Export</span>
          </button>
        </div>

        <div class="result-grid" id="result-grid">
          <article class="empty-state">
            <Sparkles size={22} />
            <h3>Your generated options will land here.</h3>
            <p>Each bucket will include candidate options, price estimates, family-fit notes, and links to keep researching.</p>
          </article>
        </div>
      </section>

      <section class="itinerary-layout" id="itinerary" aria-live="polite">
        <div class="section-title">
          <p class="eyebrow"><Clock3 size={15} /> Built itinerary</p>
          <h2 id="itinerary-title">Pick options, then build the trip.</h2>
        </div>
        <div class="itinerary-grid" id="itinerary-grid">
          <article class="empty-state">
            <Clock3 size={22} />
            <h3>No itinerary yet.</h3>
            <p>Choose the lodging, food, and activity options you like, then build a day-by-day plan.</p>
          </article>
        </div>
      </section>

      <section class="saved-layout" id="saved">
        <div class="section-title">
          <p class="eyebrow"><Save size={15} /> Saved boards</p>
          <h2>Keep the trips worth revisiting.</h2>
        </div>
        <div class="saved-list" id="saved-list"></div>
      </section>
    </main>

    <dialog class="auth-dialog" id="auth-dialog">
      <form class="auth-card" id="auth-form" method="dialog">
        <div>
          <p class="eyebrow"><Save size={15} /> Owner access</p>
          <h2>Sign in to unlock unlimited searches.</h2>
          <p id="auth-message">Use the email connected to your Supabase owner account.</p>
        </div>
        <label>
          <span>Email</span>
          <input id="auth-email" name="email" type="email" autocomplete="email" placeholder="you@example.com" />
        </label>
        <div class="auth-actions">
          <button class="icon-button" id="auth-cancel" type="button">Cancel</button>
          <button class="primary-action" type="submit">Send magic link</button>
        </div>
      </form>
    </dialog>

    <template id="category-template">
      <article class="result-card">
        <div class="result-card-header">
          <span class="result-icon"></span>
          <div>
            <p class="category-kicker"></p>
            <h3></h3>
            <p class="category-summary"></p>
          </div>
        </div>
        <div class="option-list"></div>
      </article>
    </template>

    <template id="option-template">
      <article class="option-card">
        <label class="option-select">
          <input type="checkbox" />
          <span>Add</span>
        </label>
        <div class="option-main">
          <div class="option-title-row">
            <h4></h4>
            <strong></strong>
          </div>
          <p class="option-why"></p>
          <div class="option-meta"></div>
          <a class="option-link" target="_blank" rel="noreferrer">Research</a>
        </div>
      </article>
    </template>

    <script>
      import { createClient, type SupabaseClient, type User } from "@supabase/supabase-js";

      type Budget = {
        lodging: number;
        flight: number;
        food: number;
        activity: number;
      };

      type PlanOption = {
        id: string;
        category: string;
        name: string;
        price: string;
        priceValue: number;
        why: string;
        timing: string;
        link: string;
        tags: string[];
      };

      type PlanCategory = {
        key: string;
        kicker: string;
        title: string;
        icon: string;
        summary: string;
        options: PlanOption[];
      };

      type ItineraryDay = {
        day: number;
        title: string;
        morning: string;
        lunch: string;
        afternoon: string;
        dinner: string;
        notes: string;
      };

      type TripPlan = {
        id: string;
        destination: string;
        origin: string;
        dateRange: string;
        nights: number;
        pace: string;
        priorities: string[];
        budget: Budget;
        notes: string;
        createdAt: string;
        selectedOptionIds: string[];
        itinerary: ItineraryDay[];
        categories: PlanCategory[];
      };

      type SavedTripRecord = {
        id: string;
        destination: string;
        date_range: string;
        plan: TripPlan;
        updated_at?: string;
      };

      const form = document.querySelector<HTMLFormElement>("#trip-form");
      const resultGrid = document.querySelector<HTMLDivElement>("#result-grid");
      const itineraryGrid = document.querySelector<HTMLDivElement>("#itinerary-grid");
      const planTitle = document.querySelector<HTMLHeadingElement>("#plan-title");
      const itineraryTitle = document.querySelector<HTMLHeadingElement>("#itinerary-title");
      const buildTripButton = document.querySelector<HTMLButtonElement>("#build-trip");
      const saveButton = document.querySelector<HTMLButtonElement>("#save-plan");
      const downloadButton = document.querySelector<HTMLButtonElement>("#download-plan");
      const generateButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
      const generateButtonLabel = generateButton?.querySelector<HTMLSpanElement>("span");
      const savedList = document.querySelector<HTMLDivElement>("#saved-list");
      const categoryTemplate = document.querySelector<HTMLTemplateElement>("#category-template");
      const optionTemplate = document.querySelector<HTMLTemplateElement>("#option-template");
      const startDateInput = document.querySelector<HTMLInputElement>("#start-date");
      const endDateInput = document.querySelector<HTMLInputElement>("#end-date");
      const authButton = document.querySelector<HTMLButtonElement>("#auth-button");
      const authDialog = document.querySelector<HTMLDialogElement>("#auth-dialog");
      const authForm = document.querySelector<HTMLFormElement>("#auth-form");
      const authEmailInput = document.querySelector<HTMLInputElement>("#auth-email");
      const authCancelButton = document.querySelector<HTMLButtonElement>("#auth-cancel");
      const authMessage = document.querySelector<HTMLParagraphElement>("#auth-message");
      const quotaStatus = document.querySelector<HTMLParagraphElement>("#quota-status");

      const storageKey = "family-travel-studio-plans";
      const localSearchKey = "family-travel-studio-local-searches";
      const supabaseUrl = normalizeSupabaseUrl(import.meta.env.PUBLIC_SUPABASE_URL);
      const supabaseAnonKey = cleanEnvValue(import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
      const ownerEmail = String(import.meta.env.PUBLIC_OWNER_EMAIL || "").toLowerCase();
      let supabaseConfigIssue = "";
      let supabase: SupabaseClient | null = null;
      try {
        if (!supabaseUrl || !supabaseAnonKey) {
          supabaseConfigIssue = "Supabase is not configured yet. Add PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY to the Cloudflare build variables, then redeploy.";
        } else {
          new URL(supabaseUrl);
          supabase = createClient(supabaseUrl, supabaseAnonKey);
        }
      } catch {
        supabaseConfigIssue = "Supabase could not start. Check that PUBLIC_SUPABASE_URL is a valid https://...supabase.co URL or Supabase project ref.";
      }
      let activePlan: TripPlan | null = null;
      let currentUser: User | null = null;

      const today = new Date();
      const nextMonth = new Date(today.getFullYear(), today.getMonth() + 1, today.getDate());
      const returnDate = new Date(nextMonth);
      returnDate.setDate(nextMonth.getDate() + 5);
      if (startDateInput && endDateInput) {
        startDateInput.min = toDateInput(today);
        endDateInput.min = toDateInput(today);
        startDateInput.value = toDateInput(nextMonth);
        endDateInput.value = toDateInput(returnDate);
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(form);
        setLoadingState(true, data);
        try {
          const generatedPlan = await generateTripPlan(data);
          if (!generatedPlan) return;
          activePlan = generatedPlan;
          renderPlan(activePlan);
        } finally {
          setLoadingState(false);
        }
      });

      buildTripButton?.addEventListener("click", () => {
        if (!activePlan) return;
        activePlan.itinerary = buildItinerary(activePlan);
        renderItinerary(activePlan);
        document.querySelector("#itinerary")?.scrollIntoView({ behavior: "smooth" });
      });

      saveButton?.addEventListener("click", async () => {
        if (!activePlan) return;
        await saveActivePlan(activePlan);
      });

      authButton?.addEventListener("click", async () => {
        if (currentUser) {
          await supabase?.auth.signOut();
          currentUser = null;
          updateAuthUi();
          await renderSavedPlans();
          return;
        }
        setAuthMessage(supabaseConfigIssue || "Use the email connected to your Supabase owner account.");
        openAuthDialog();
      });

      authCancelButton?.addEventListener("click", () => authDialog?.close());

      authForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!supabase || !authEmailInput || !authMessage) {
          setAuthMessage(supabaseConfigIssue || "Supabase is not configured yet. Add your Supabase URL and anon key to enable sign in.");
          return;
        }

        const email = authEmailInput.value.trim();
        if (!email) return;
        const { error } = await supabase.auth.signInWithOtp({
          email,
          options: { emailRedirectTo: window.location.origin }
        });

        setAuthMessage(error ? error.message : "Magic link sent. Check your email, then return here.");
      });

      downloadButton?.addEventListener("click", () => {
        if (!activePlan) return;
        const blob = new Blob([JSON.stringify(activePlan, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement("a");
        anchor.href = url;
        anchor.download = `${slugify(activePlan.destination)}-family-trip.json`;
        anchor.click();
        URL.revokeObjectURL(url);
      });

      startDateInput?.addEventListener("change", () => {
        if (!startDateInput.value || !endDateInput) return;
        endDateInput.min = startDateInput.value;
        if (endDateInput.value < startDateInput.value) {
          const next = new Date(`${startDateInput.value}T12:00:00`);
          next.setDate(next.getDate() + 4);
          endDateInput.value = toDateInput(next);
        }
      });

      async function initializeAuth() {
        if (!supabase) {
          updateAuthUi();
          await renderSavedPlans();
          return;
        }

        const { data } = await supabase.auth.getSession();
        currentUser = data.session?.user || null;
        updateAuthUi();
        await renderSavedPlans();

        supabase.auth.onAuthStateChange(async (_event, session) => {
          currentUser = session?.user || null;
          updateAuthUi();
          await renderSavedPlans();
        });
      }

      function updateAuthUi() {
        if (!authButton || !quotaStatus) return;
        const isOwner = isOwnerUser();
        if (!supabase) {
          authButton.textContent = "Sign in";
          quotaStatus.textContent = supabaseConfigIssue || "Supabase is not configured yet. Preview uses local saves and local demo search counts.";
          return;
        }

        if (currentUser) {
          authButton.textContent = "Sign out";
          quotaStatus.textContent = isOwner
            ? `Signed in as owner (${currentUser.email}). AI searches are unlimited.`
            : `Signed in as ${currentUser.email}. Public search limits still apply unless this email is the configured owner.`;
          return;
        }

        const used = getLocalSearchCount();
        authButton.textContent = "Sign in";
        quotaStatus.textContent = `Public demo searches used locally: ${used}/3. Sign in as owner for unlimited.`;
      }

      function isOwnerUser() {
        return Boolean(currentUser?.email && ownerEmail && currentUser.email.toLowerCase() === ownerEmail);
      }

      function setAuthMessage(message: string) {
        if (authMessage) authMessage.textContent = message;
      }

      function openAuthDialog() {
        if (!authDialog) return;
        if (authDialog.open) return;
        try {
          authDialog.showModal();
        } catch {
          authDialog.setAttribute("open", "");
        }
      }

      function cleanEnvValue(value: unknown) {
        return String(value || "").trim().replace(/^["']|["']$/g, "");
      }

      function normalizeSupabaseUrl(value: unknown) {
        const cleaned = cleanEnvValue(value).replace(/\/+$/, "");
        if (!cleaned || /^https?:\/\//i.test(cleaned)) return cleaned;
        if (/^[a-z0-9]+$/i.test(cleaned)) return `https://${cleaned}.supabase.co`;
        return cleaned;
      }

      async function getAccessToken() {
        if (!supabase) return null;
        const { data } = await supabase.auth.getSession();
        return data.session?.access_token || null;
      }

      async function generateTripPlan(data: FormData): Promise<TripPlan | null> {
        const token = await getAccessToken();
        if (quotaStatus) quotaStatus.textContent = "Building AI trip options...";
        try {
          const response = await fetch("/api/generate-trip", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              ...(token ? { Authorization: `Bearer ${token}` } : {})
            },
            body: JSON.stringify({
              tripInput: formDataToTripInput(data),
              localPreview: !supabase
            })
          });

          if (response.ok) {
            const result = await response.json();
            if (result.plan) {
              if (quotaStatus) {
                quotaStatus.textContent = result.isOwner
                  ? "Owner mode active. AI trip options generated."
                  : `AI trip options generated. ${result.remaining} of 3 public searches remaining.`;
              }
              return normalizeSavedPlan(result.plan);
            }
            if (quotaStatus) {
              quotaStatus.textContent = result.message || "AI generation is unavailable, using a local preview.";
            }
            return createPlan(data);
          }

          if (response.status === 402 || response.status === 429) {
            const result = await response.json().catch(() => ({ message: "Demo search limit reached. Sign in to continue." }));
            if (quotaStatus) quotaStatus.textContent = result.message;
            openAuthDialog();
            return null;
          }

          const result = await response.json().catch(() => ({ message: "AI generation failed. Using a local preview." }));
          if (quotaStatus) quotaStatus.textContent = result.message;
          return createPlan(data);
        } catch {
          // Astro preview does not serve Pages Functions; keep local development usable.
        }

        if (isOwnerUser()) {
          if (quotaStatus) quotaStatus.textContent = "Owner mode active locally. Using local preview because the Worker API is unavailable.";
          return createPlan(data);
        }

        const used = getLocalSearchCount();
        if (used >= 3 && supabase) {
          if (quotaStatus) quotaStatus.textContent = "Demo search limit reached. Sign in as owner to continue.";
          openAuthDialog();
          return null;
        }

        localStorage.setItem(localSearchKey, String(used + 1));
        if (quotaStatus) quotaStatus.textContent = `Local preview search ${used + 1}/3. Production uses the server-side Supabase gate.`;
        return createPlan(data);
      }

      function formDataToTripInput(data: FormData) {
        return {
          destination: String(data.get("destination") || ""),
          origin: String(data.get("origin") || ""),
          startDate: String(data.get("startDate") || ""),
          endDate: String(data.get("endDate") || ""),
          kids: String(data.get("kids") || ""),
          pace: String(data.get("pace") || ""),
          lodgingBudget: Number(data.get("lodgingBudget") || 0),
          flightBudget: Number(data.get("flightBudget") || 0),
          foodBudget: Number(data.get("foodBudget") || 0),
          activityBudget: Number(data.get("activityBudget") || 0),
          priorities: data.getAll("priority").map(String),
          notes: String(data.get("notes") || "")
        };
      }

      function getLocalSearchCount() {
        return Number(localStorage.getItem(localSearchKey) || 0);
      }

      function createPlan(data: FormData): TripPlan {
        const destination = String(data.get("destination") || "San Diego, CA").trim();
        const origin = String(data.get("origin") || "AUS").trim().toUpperCase();
        const startDate = new Date(`${data.get("startDate")}T12:00:00`);
        const endDate = new Date(`${data.get("endDate")}T12:00:00`);
        const nights = Math.max(1, differenceInDays(startDate, endDate));
        const pace = String(data.get("pace") || "easy");
        const priorities = data.getAll("priority").map(String);
        const notes = String(data.get("notes") || "").trim();
        const budget = {
          lodging: Number(data.get("lodgingBudget") || 360),
          flight: Number(data.get("flightBudget") || 360),
          food: Number(data.get("foodBudget") || 80),
          activity: Number(data.get("activityBudget") || 100)
        };
        const dateRange = `${startDate.toLocaleDateString(undefined, { month: "short", day: "numeric" })} - ${endDate.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" })}`;
        const destinationProfile = profileDestination(destination);

        return {
          id: crypto.randomUUID(),
          destination,
          origin,
          dateRange,
          nights,
          pace,
          priorities,
          budget,
          notes,
          createdAt: new Date().toISOString(),
          selectedOptionIds: [],
          itinerary: [],
          categories: makeCategories(destination, origin, destinationProfile, budget, priorities, pace)
        };
      }

      function makeCategories(destination: string, origin: string, profile: ReturnType<typeof profileDestination>, budget: Budget, priorities: string[], pace: string): PlanCategory[] {
        return [
          {
            key: "lodging",
            kicker: "Lodging",
            title: "Stay options",
            icon: "hotel",
            summary: `${profile.bestArea}; filtered around $${budget.lodging}/night.`,
            options: [
              makeOption("lodging", "Family suite near the easy base", Math.round(budget.lodging * 0.92), "per night", `Best fit if you want ${profile.bestArea}, stroller storage, a fridge, and low-friction naps.`, "Use as the main base for every night.", destination, ["suite", "walkable", priorities.includes("pool") ? "pool" : "quiet"]),
              makeOption("lodging", "Apartment-style stay with kitchen", Math.round(budget.lodging * 0.82), "per night", "Best fit for bottles, toddler breakfast, laundry, and eating one meal in the room each day.", "Use when kitchen access matters more than resort amenities.", destination, ["kitchen", "laundry", "family space"]),
              makeOption("lodging", "Resort or hotel with pool reset", Math.round(budget.lodging * 1.08), "per night", "Best fit if the pool is part of the plan and you want an easy afternoon fallback.", "Use for arrival day, post-nap resets, and weather-proof downtime.", destination, ["pool", "onsite dining", "easy arrival"])
            ]
          },
          {
            key: "flights",
            kicker: "Flights",
            title: "Southwest-first routes",
            icon: "plane",
            summary: `Targeting around $${budget.flight}/person with toddler-friendly timing.`,
            options: [
              makeFlightOption("flights", "Morning nonstop target", Math.round(budget.flight * 0.95), origin, destination, "Shortest travel day, best toddler odds, and fewer connection failure points.", "Outbound 8-10 a.m.; return before dinner."),
              makeFlightOption("flights", "One-stop with breathing room", Math.round(budget.flight * 0.82), origin, destination, "Usually cheaper while preserving a diaper/snack/stroller buffer between segments.", "Connection window around 75-110 minutes."),
              makeFlightOption("flights", "Flexible fare watch", Math.round(budget.flight * 1.05), origin, destination, "Useful if points, companion pass, or Southwest fare changes can improve the final booking.", "Track fare drops after the first booking.")
            ]
          },
          {
            key: "food",
            kicker: "Restaurants",
            title: "Meal options",
            icon: "utensils",
            summary: `${profile.foodAngle}; meals around $${budget.food} for four.`,
            options: [
              makeOption("food", profile.restaurantNames[0], Math.round(budget.food * 0.78), "meal for 4", "Fast casual, flexible seating, and a menu that can work for toddlers and adults.", "Good lunch or first-night dinner.", destination, ["quick", "kid-friendly", "low wait"]),
              makeOption("food", profile.restaurantNames[1], Math.round(budget.food * 1.05), "meal for 4", "A more memorable local meal that still works with early dinner timing.", "Book or arrive around 5:00 p.m.", destination, ["local favorite", "early dinner", "patio"]),
              makeOption("food", "Grocery + breakfast setup", Math.round(budget.food * 0.55), "stock-up", "Milk, fruit, pouches, easy breakfasts, and parent coffee supplies reduce morning friction.", "Do this on arrival day.", destination, ["breakfast", "snacks", "room reset"])
            ]
          },
          {
            key: "activities",
            kicker: "Things to do",
            title: "Activity options",
            icon: "star",
            summary: `Built around ${pace} pace and about $${budget.activity}/day.`,
            options: [
              makeOption("activities", profile.activityNames[0], Math.round(budget.activity * 0.95), "family", profile.activityWhy[0], "Best as the first full morning.", destination, ["anchor", "morning", "stroller-aware"]),
              makeOption("activities", profile.activityNames[1], Math.round(budget.activity * 0.35), "family", profile.activityWhy[1], "Use after breakfast or before nap.", destination, ["low cost", "easy exit", "outdoors"]),
              makeOption("activities", profile.activityNames[2], Math.round(budget.activity * 0.7), "family", profile.activityWhy[2], "Save as a weather-proof or low-energy option.", destination, ["backup", "short visit", "flexible"])
            ]
          }
        ];
      }

      function makeOption(category: string, name: string, amount: number, unit: string, why: string, timing: string, destination: string, tags: string[]): PlanOption {
        return {
          id: `${category}-${slugify(name)}`,
          category,
          name,
          price: `$${amount} ${unit}`,
          priceValue: amount,
          why,
          timing,
          link: searchUrl(`${name} ${destination}`),
          tags
        };
      }

      function makeFlightOption(category: string, name: string, amount: number, origin: string, destination: string, why: string, timing: string): PlanOption {
        return {
          id: `${category}-${slugify(name)}`,
          category,
          name,
          price: `$${amount} per person`,
          priceValue: amount,
          why,
          timing,
          link: searchUrl(`Southwest flights ${origin || "home airport"} to ${destination}`),
          tags: ["Southwest", origin || "home", "family boarding"]
        };
      }

      function renderPlan(plan: TripPlan) {
        if (!resultGrid || !categoryTemplate || !optionTemplate || !planTitle || !saveButton || !downloadButton || !buildTripButton) return;
        planTitle.textContent = `${plan.destination} | ${plan.dateRange}`;
        saveButton.disabled = false;
        downloadButton.disabled = false;
        buildTripButton.disabled = false;
        resultGrid.innerHTML = "";

        plan.categories.forEach((category) => {
          const fragment = categoryTemplate.content.cloneNode(true) as DocumentFragment;
          const card = fragment.querySelector<HTMLElement>(".result-card");
          const icon = fragment.querySelector<HTMLElement>(".result-icon");
          const kicker = fragment.querySelector<HTMLElement>(".category-kicker");
          const title = fragment.querySelector<HTMLHeadingElement>("h3");
          const summary = fragment.querySelector<HTMLElement>(".category-summary");
          const list = fragment.querySelector<HTMLDivElement>(".option-list");

          if (!card || !icon || !kicker || !title || !summary || !list) return;
          card.dataset.category = category.key;
          icon.innerHTML = iconFor(category.icon);
          kicker.textContent = category.kicker;
          title.textContent = category.title;
          summary.textContent = category.summary;

          category.options.forEach((option, index) => {
            const optionFragment = optionTemplate.content.cloneNode(true) as DocumentFragment;
            const optionCard = optionFragment.querySelector<HTMLElement>(".option-card");
            const checkbox = optionFragment.querySelector<HTMLInputElement>("input");
            const name = optionFragment.querySelector<HTMLHeadingElement>("h4");
            const price = optionFragment.querySelector<HTMLElement>("strong");
            const why = optionFragment.querySelector<HTMLElement>(".option-why");
            const meta = optionFragment.querySelector<HTMLElement>(".option-meta");
            const link = optionFragment.querySelector<HTMLAnchorElement>(".option-link");

            if (!optionCard || !checkbox || !name || !price || !why || !meta || !link) return;
            checkbox.checked = index === 0 || plan.selectedOptionIds.includes(option.id);
            optionCard.dataset.optionId = option.id;
            name.textContent = option.name;
            price.textContent = option.price;
            why.textContent = option.why;
            renderMetaPills(meta, [option.timing, ...(option.tags || [])]);
            link.href = option.link;
            link.textContent = category.key === "flights" ? "Search flights" : "Open search";
            if (checkbox.checked && !plan.selectedOptionIds.includes(option.id)) {
              plan.selectedOptionIds.push(option.id);
            }
            checkbox.addEventListener("change", () => updateSelection(option.id, checkbox.checked));
            list.append(optionFragment);
          });

          resultGrid.append(fragment);
        });
      }

      function setLoadingState(isLoading: boolean, data?: FormData) {
        document.body.classList.toggle("is-loading", isLoading);
        if (generateButton) generateButton.disabled = isLoading;
        if (generateButtonLabel) generateButtonLabel.textContent = isLoading ? "Building options..." : "Generate options";
        if (!isLoading && buildTripButton && !activePlan) buildTripButton.disabled = true;
        if (!isLoading && saveButton && !activePlan) saveButton.disabled = true;
        if (!isLoading && downloadButton && !activePlan) downloadButton.disabled = true;

        if (isLoading && data) {
          renderLoadingState(String(data.get("destination") || "your trip"));
        }
      }

      function renderLoadingState(destination: string) {
        if (!resultGrid || !planTitle || !saveButton || !downloadButton || !buildTripButton) return;
        planTitle.textContent = `Building ${destination} options...`;
        saveButton.disabled = true;
        downloadButton.disabled = true;
        buildTripButton.disabled = true;
        resultGrid.innerHTML = ["Lodging", "Flights", "Restaurants", "Things to do"]
          .map(
            (label) => `
              <article class="result-card loading-card" aria-label="Loading ${label}">
                <div class="result-card-header">
                  <span class="loading-icon"></span>
                  <div>
                    <p class="category-kicker">${label}</p>
                    <h3><span class="skeleton skeleton-title"></span></h3>
                    <p class="category-summary"><span class="skeleton skeleton-line"></span></p>
                  </div>
                </div>
                <div class="option-list">
                  ${[1, 2, 3]
                    .map(
                      () => `
                        <article class="option-card skeleton-option">
                          <span class="skeleton-check"></span>
                          <div class="option-main">
                            <span class="skeleton skeleton-title"></span>
                            <span class="skeleton skeleton-line"></span>
                            <span class="skeleton skeleton-line short"></span>
                          </div>
                        </article>
                      `
                    )
                    .join("")}
                </div>
              </article>
            `
          )
          .join("");
      }

      function renderMetaPills(container: HTMLElement, values: string[]) {
        container.innerHTML = "";
        values
          .map((value) => value.trim())
          .filter(Boolean)
          .forEach((value) => {
            const pill = document.createElement("span");
            pill.textContent = value;
            container.append(pill);
          });
      }

      function updateSelection(optionId: string, selected: boolean) {
        if (!activePlan) return;
        activePlan.selectedOptionIds = selected
          ? Array.from(new Set([...activePlan.selectedOptionIds, optionId]))
          : activePlan.selectedOptionIds.filter((id) => id !== optionId);
        activePlan.itinerary = [];
        renderItinerary(activePlan);
      }

      function buildItinerary(plan: TripPlan): ItineraryDay[] {
        const lodging = selectedOptions(plan, "lodging");
        const food = itineraryOptions(plan, "food");
        const activities = itineraryOptions(plan, "activities");
        const flights = selectedOptions(plan, "flights");
        const base = lodging[0]?.name || "chosen lodging base";
        const outbound = flights[0]?.name || "arrival travel";
        const days = Math.min(plan.nights + 1, plan.pace === "full" ? 6 : 5);

        return Array.from({ length: days }, (_, index) => {
          const day = index + 1;
          const activity = activities[index % Math.max(activities.length, 1)];
          const meal = food[index % Math.max(food.length, 1)];
          const backupMeal = food[(index + 1) % Math.max(food.length, 1)];

          if (day === 1) {
            return {
              day,
              title: "Arrival and settle-in",
              morning: outbound,
              lunch: meal?.name || "simple airport or arrival lunch",
              afternoon: `Check into ${base}, stock snacks, and keep the first outing optional.`,
              dinner: backupMeal?.name || "easy early dinner near the hotel",
              notes: "Protect bedtime and do not make arrival day carry the trip."
            };
          }

          if (day === days) {
            return {
              day,
              title: "Easy departure day",
              morning: "Pack, breakfast, and one short walk or playground stop.",
              lunch: meal?.name || "quick lunch before travel",
              afternoon: "Return flight buffer, stroller gate-check, and snack reset.",
              dinner: "Home or airport fallback meal.",
              notes: "No ticketed activity unless the flight is late afternoon or evening."
            };
          }

          return {
            day,
            title: activity?.name || "Flexible family day",
            morning: activity ? `${activity.name}: ${activity.timing}` : "Choose one short morning anchor.",
            lunch: meal?.name || "counter-service lunch close to the morning area",
            afternoon: plan.pace === "full" ? "Second short stop, then nap or pool reset." : `Nap or downtime at ${base}.`,
            dinner: backupMeal?.name || "early casual dinner",
            notes: plan.notes || "Keep one backup playground, coffee stop, or hotel reset ready."
          };
        });
      }

      function renderItinerary(plan: TripPlan) {
        if (!itineraryGrid || !itineraryTitle) return;
        itineraryTitle.textContent = plan.itinerary.length
          ? `${plan.destination} itinerary built from ${plan.selectedOptionIds.length} selected options`
          : "Pick options, then build the trip.";
        itineraryGrid.innerHTML = "";

        if (!plan.itinerary.length) {
          itineraryGrid.innerHTML = `
            <article class="empty-state">
              <h3>No itinerary yet.</h3>
              <p>Choose the lodging, food, and activity options you like, then build a day-by-day plan.</p>
            </article>
          `;
          return;
        }

        plan.itinerary.forEach((day) => {
          const card = document.createElement("article");
          card.className = "itinerary-card";
          card.innerHTML = `
            <p>Day ${day.day}</p>
            <h3>${day.title}</h3>
            <dl>
              <div><dt>Morning</dt><dd>${day.morning}</dd></div>
              <div><dt>Lunch</dt><dd>${day.lunch}</dd></div>
              <div><dt>Afternoon</dt><dd>${day.afternoon}</dd></div>
              <div><dt>Dinner</dt><dd>${day.dinner}</dd></div>
            </dl>
            <span>${day.notes}</span>
          `;
          itineraryGrid.append(card);
        });
      }

      function selectedOptions(plan: TripPlan, category: string) {
        const options = plan.categories.find((item) => item.key === category)?.options || [];
        const selected = options.filter((option) => plan.selectedOptionIds.includes(option.id));
        return selected.length ? selected : options.slice(0, 1);
      }

      function itineraryOptions(plan: TripPlan, category: string) {
        const options = plan.categories.find((item) => item.key === category)?.options || [];
        const selected = options.filter((option) => plan.selectedOptionIds.includes(option.id));
        return selected.length > 1 ? selected : options;
      }

      async function saveActivePlan(plan: TripPlan) {
        if (supabase && currentUser) {
          const { error } = await supabase.from("saved_trips").upsert({
            id: plan.id,
            user_id: currentUser.id,
            destination: plan.destination,
            date_range: plan.dateRange,
            plan,
            updated_at: new Date().toISOString()
          });

          if (!error) {
            await renderSavedPlans();
            return;
          }

          if (quotaStatus) quotaStatus.textContent = `Cloud save failed: ${error.message}. Saved locally instead.`;
        }

        const plans = getLocalSavedPlans();
        const withoutDuplicate = plans.filter((savedPlan) => savedPlan.id !== plan.id);
        localStorage.setItem(storageKey, JSON.stringify([plan, ...withoutDuplicate].slice(0, 12)));
        await renderSavedPlans();
      }

      async function renderSavedPlans() {
        if (!savedList) return;
        const plans = await getSavedPlans();
        savedList.innerHTML = "";

        if (!plans.length) {
          savedList.innerHTML = `<p class="muted">${currentUser ? "No cloud-saved boards yet." : "No local saved boards yet."}</p>`;
          return;
        }

        plans.forEach((plan) => {
          const item = document.createElement("article");
          item.className = "saved-item";
          item.innerHTML = `
            <div>
              <p>${plan.dateRange}</p>
              <h3>${plan.destination}</h3>
              <span>${plan.nights} nights | ${plan.selectedOptionIds?.length || 0} selected</span>
            </div>
            <div class="saved-actions">
              <button type="button" data-action="load" data-id="${plan.id}" title="Load saved board">Load</button>
              <button type="button" data-action="delete" data-id="${plan.id}" title="Delete saved board">${iconFor("trash")}</button>
            </div>
          `;
          savedList.append(item);
        });

        savedList.querySelectorAll<HTMLButtonElement>("button").forEach((button) => {
          button.addEventListener("click", async () => {
            const id = button.dataset.id;
            const action = button.dataset.action;
            if (!id) return;
            if (action === "load") {
              const plan = (await getSavedPlans()).find((savedPlan) => savedPlan.id === id);
              if (!plan) return;
              activePlan = normalizeSavedPlan(plan);
              renderPlan(activePlan);
              renderItinerary(activePlan);
              document.querySelector("#results")?.scrollIntoView({ behavior: "smooth" });
            }
            if (action === "delete") {
              await deleteSavedPlan(id);
              await renderSavedPlans();
            }
          });
        });
      }

      function normalizeSavedPlan(plan: TripPlan): TripPlan {
        return {
          ...plan,
          selectedOptionIds: plan.selectedOptionIds || [],
          itinerary: plan.itinerary || []
        };
      }

      async function deleteSavedPlan(id: string) {
        if (supabase && currentUser) {
          await supabase.from("saved_trips").delete().eq("id", id).eq("user_id", currentUser.id);
          return;
        }

        localStorage.setItem(storageKey, JSON.stringify(getLocalSavedPlans().filter((savedPlan) => savedPlan.id !== id)));
      }

      async function getSavedPlans(): Promise<TripPlan[]> {
        if (supabase && currentUser) {
          const { data, error } = await supabase
            .from("saved_trips")
            .select("id,destination,date_range,plan,updated_at")
            .eq("user_id", currentUser.id)
            .order("updated_at", { ascending: false });

          if (!error && data) {
            return (data as SavedTripRecord[]).map((record) => normalizeSavedPlan(record.plan));
          }

          if (quotaStatus && error) quotaStatus.textContent = `Cloud saves unavailable: ${error.message}`;
        }

        return getLocalSavedPlans();
      }

      function getLocalSavedPlans(): TripPlan[] {
        try {
          return JSON.parse(localStorage.getItem(storageKey) || "[]").map(normalizeSavedPlan);
        } catch {
          return [];
        }
      }

      function profileDestination(destination: string) {
        const lower = destination.toLowerCase();
        if (lower.includes("san diego")) {
          return {
            bestArea: "Mission Bay, Coronado, or La Jolla Shores",
            foodAngle: "fish tacos, casual patios, and breakfast spots",
            restaurantNames: ["The Taco Stand La Jolla", "Liberty Public Market", "Breakfast Republic"],
            activityNames: ["San Diego Zoo", "Mission Bay playground and beach walk", "Birch Aquarium"],
            activityWhy: [
              "Iconic, stroller-friendly, and easy to treat as the one major activity of the day.",
              "Low-cost outdoor time with easy exits, water views, and space to move.",
              "Shorter indoor visit with strong toddler appeal and a calmer backup for weather."
            ]
          };
        }
        if (lower.includes("orlando")) {
          return {
            bestArea: "Lake Buena Vista or a resort with shuttle coverage",
            foodAngle: "resort restaurants, early character meals, and easy pizza nights",
            restaurantNames: ["Primo Piatto", "Disney Springs quick-service cluster", "Hash House A Go Go"],
            activityNames: ["Magic Kingdom morning block", "Resort pool and splash pad", "Crayola Experience"],
            activityWhy: [
              "Classic family anchor, best handled as an early block with a clear exit plan.",
              "Built-in decompression with no extra transportation complexity.",
              "Indoor, colorful, and flexible for toddlers when weather gets rough."
            ]
          };
        }
        if (lower.includes("chicago")) {
          return {
            bestArea: "River North, Gold Coast, or Lincoln Park",
            foodAngle: "early deep-dish, food halls, and neighborhood cafes",
            restaurantNames: ["Beatrix River North", "Lou Malnati's Gold Coast", "Time Out Market Chicago"],
            activityNames: ["Lincoln Park Zoo", "Maggie Daley Park", "Shedd Aquarium"],
            activityWhy: [
              "Free, stroller-friendly, and easy to pair with playground or park time.",
              "Great toddler energy burn with skyline views and easy downtown access.",
              "Strong weather-proof anchor with enough variety for a short visit."
            ]
          };
        }
        if (lower.includes("denver")) {
          return {
            bestArea: "Cherry Creek, LoDo, or a foothills-adjacent hotel",
            foodAngle: "breakfast burritos, casual patios, and market halls",
            restaurantNames: ["Denver Central Market", "Snooze Union Station", "Avanti Food & Beverage"],
            activityNames: ["Denver Botanic Gardens", "Colorado Railroad Museum", "Washington Park playground"],
            activityWhy: [
              "Beautiful, stroller-friendly, and calmer than a packed museum morning.",
              "A toddler-friendly anchor with trains, outdoor space, and flexible pacing.",
              "Easy outdoor reset with room to move and low commitment."
            ]
          };
        }
        return {
          bestArea: "a central, walkable neighborhood near parks and casual restaurants",
          foodAngle: "casual local favorites with outdoor seating and quick service",
          restaurantNames: ["Family-friendly local cafe", "Casual market hall", "Early dinner patio spot"],
          activityNames: ["Top family attraction", "Best nearby playground", "Children-friendly museum or aquarium"],
          activityWhy: [
            "A signature morning anchor with enough interest for adults and kids.",
            "Low-cost outdoor reset with an easy exit whenever toddlers are done.",
            "A flexible backup that works when weather or nap timing changes."
          ]
        };
      }

      function iconFor(name: string) {
        const icons: Record<string, string> = {
          hotel: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 21h18"/><path d="M5 21V7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14"/><path d="M9 21v-6h6v6"/><path d="M8 9h.01"/><path d="M12 9h.01"/><path d="M16 9h.01"/></svg>',
          plane: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.8 19.2 16 11l3.5-3.5c1.5-1.5 2-3.5 1-4.5s-3 0-4.5 1L12.5 7.5 4.3 5.7c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3l5.6 3.4-2.1 2.1-2.6-.4c-.4-.1-.7.1-.9.4l-.2.4c-.2.4-.1.9.2 1.2l2.2 2.2 2.2 2.2c.3.3.8.4 1.2.2l.4-.2c.3-.2.5-.5.4-.9l-.4-2.6 2.1-2.1 3.4 5.6c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>',
          utensils: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 2v7c0 1.7 1.3 3 3 3s3-1.3 3-3V2"/><path d="M6 2v20"/><path d="M21 15V2c-3 1-5 4-5 8v5h5z"/><path d="M21 15v7"/></svg>',
          star: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 2 3.1 6.3 6.9 1-5 4.9 1.2 6.8-6.2-3.3L5.8 21 7 14.2 2 9.3l6.9-1L12 2z"/></svg>',
          clock: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>',
          trash: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="m19 6-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>'
        };
        return icons[name] || icons.star;
      }

      function searchUrl(query: string) {
        return `https://www.google.com/search?q=${encodeURIComponent(query)}`;
      }

      function differenceInDays(start: Date, end: Date) {
        return Math.ceil((end.getTime() - start.getTime()) / 86400000);
      }

      function toDateInput(date: Date) {
        return date.toISOString().slice(0, 10);
      }

      function slugify(value: string) {
        return value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
      }

      initializeAuth();
    </script>
  </body>
</html>
